# Print unique remediation suggestions at the end, grouped by Log
Write-Host "`n=== Suggested Remediations Summary ===" -ForegroundColor Cyan

foreach ($log in $logs) {
    $remediationsForLog = $allRemediations | Where-Object { $_.Log -eq $log } | Select-Object -ExpandProperty Remediation | Sort-Object -Unique

    if ($remediationsForLog.Count -gt 0) {
        Write-Host "`nFrom $log Log:" -ForegroundColor Cyan
        foreach ($remediation in $remediationsForLog) {
            Write-Host "- $remediation" -ForegroundColor DarkGreen
        }
    }
    else {
        Write-Host "`nNo remediations found for $log log." -ForegroundColor Green
    }
}
