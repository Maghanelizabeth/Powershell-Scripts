##I developed this tool to simplify and accelerate the diagnosis of critical system errors on Windows machines.
##It is designed primarily for junior technicians or users with limited experience interpreting Windows Event Viewer logs, enabling them to quickly identify and respond to system issues without deep log analysis knowledge.

##The tool automatically identifies high-impact Event IDs associated with system services, hardware failures, power events, BIOS and CPU anomalies, memory pressure, disk errors, and PCI-related faults. 
##For each detected event, it generates a clear human-readable explanation along with practical remediation steps.

##How to Use:
	1. Save the Script: Copy the above script into a text editor and save it as log_diagnoser.ps1.
	2. Run the Script:
		○ Open PowerShell as Administrator.
		○ Navigate to the directory where the script is saved.
##Execute the script by typing .\log_diagnoser.ps1.




$logs = @("System", "Application", "Security")
$startTime = (Get-Date).AddHours(-2)  # Only get events from the last 2 hours

# Store all remediations found with source log info
$allRemediations = @()

foreach ($log in $logs) {
    Write-Host "`n=== Errors in $log Log (Last 2 Hours) ===" -ForegroundColor Cyan

    try {
        $filter = @{
            LogName   = $log
            Level     = 2             # Error level
            StartTime = $startTime
        }

        $errorEvents = Get-WinEvent -FilterHashtable $filter -ErrorAction Stop

        if ($errorEvents.Count -eq 0) {
            Write-Host "No errors found in $log log in the last 2 hours." -ForegroundColor Green
        } else {
            foreach ($event in $errorEvents) {
                Write-Host "[$($event.TimeCreated)] Event ID: $($event.Id) Source: $($event.ProviderName)"
                Write-Host "Message: $($event.Message)"

