This PowerShell script is a comprehensive Windows Update troubleshooting and system diagnostics utility designed to collect, analyze, 
and correlate update-related issues across system logs and generate actionable remediation guidance to junior Cybersecurity Analysts.


How to Use:
	1. Save the Script: Copy the above script into a text editor and save it as Get-WindowsUpdateDiagnostics.ps1.
	2. Run the Script:
		○ Open PowerShell as Administrator.
		○ Navigate to the directory where the script is saved.
		○ Execute the script by typing .\Get-WindowsUpdateDiagnostics.ps1.
	3. Review the Report:
		○ The script will generate a .txt file on the C: drive with a timestamped filename, e.g., C:\WindowsUpdateDiagnostics_20250610_115108.txt.
		○ This file will contain:
			§ System summary.
			§ Extracted errors from WindowsUpdate.log and CBS.log.
			§ List of failed KB updates.
			§ Suggested remediations.
Relevant Event Viewer logs.


# Get-WindowsUpdateDiagnostics.ps1
 
function Get-SystemSummary {
    Write-Output "=== System Summary ==="
    $os = Get-CimInstance -ClassName Win32_OperatingSystem
    $cpu = Get-CimInstance -ClassName Win32_Processor
    $freeSpace = Get-PSDrive -PSProvider 'FileSystem' | Where-Object {$_.Name -eq 'C'}
    $ramKB = $os.TotalVisibleMemorySize
    $ramGB = [math]::Round($ramKB / 1024 / 1024, 2)
 
    [PSCustomObject]@{
        OS              = $os.Caption
        OSVersion       = $os.Version
        Architecture    = $os.OSArchitecture
        LastBootTime    = $os.LastBootUpTime
        CPU             = $cpu.Name
        RAM_GB          = $ramGB
        Disk_C_Free_GB  = [math]::Round($freeSpace.Free / 1GB, 2)
        Disk_C_Total_GB = [math]::Round($freeSpace.Used / 1GB + $freeSpace.Free / 1GB, 2)
    }
}

function Parse-WindowsUpdateLog {
    param($logPath)
    Write-Output "`n=== WindowsUpdate.log Issues (Today Only) ==="

    if (-not (Test-Path $logPath)) {
        Write-Warning "WindowsUpdate.log not found at $logPath"
        return
    }

    $startOfToday = (Get-Date).Date
    $keywords = @('error', 'fail', 'failed', 'failing', 'warning')
    $logLines = Get-Content -Path $logPath
    $filteredLines = @()
    $lastTimestamp = $null

    foreach ($line in $logLines) {
        # Extract timestamp from the beginning of the line with format: yyyy/MM/dd HH:mm:ss.fffffff
        if ($line -match '^(\d{4}/\d{2}/\d{2} \d{2}:\d{2}:\d{2}\.\d+)') {
            $timestampString = $matches[1]
            try {
                # Parse with exact format (up to 7 fractional seconds)
                $lastTimestamp = [datetime]::ParseExact($timestampString, 'yyyy/MM/dd HH:mm:ss.fffffff', $null)
            } catch {
                # fallback to generic parse if needed
                $lastTimestamp = [datetime]::Parse($timestampString)
            }
        }

        # Check if line contains any of the keywords (case-insensitive)
        $containsKeyword = $false
        foreach ($keyword in $keywords) {
            if ($line.IndexOf($keyword, [System.StringComparison]::InvariantCultureIgnoreCase) -ge 0) {
                $containsKeyword = $true
                break
            }
        }

        if ($containsKeyword -and $lastTimestamp -and $lastTimestamp.Date -eq $startOfToday) {
            $filteredLines += $line
        }
    }

    if ($filteredLines.Count -eq 0) {
        Write-Output "No matching entries found in WindowsUpdate.log for today."
    } else {
        $filteredLines
    }
}


 
function Parse-CBSLog {
    param($logPath)
    Write-Output "`n=== CBS.log Failures (Today Only) ==="

    if (-not (Test-Path $logPath)) {
        Write-Warning "CBS.log not found at $logPath"
        return
    }

    $startOfToday = (Get-Date).Date
    $keywords = @('error', 'fail', 'failed', 'failure', 'warning')
    $logLines = Get-Content -Path $logPath
    $filteredLines = @()
    $lastTimestamp = $null

    foreach ($line in $logLines) {
        # Extract timestamp from the beginning of the line if possible
        # CBS.log format usually starts with "YYYY-MM-DD HH:MM:SS"
        if ($line -match '^(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})') {
            $timestampString = $matches[1]
            try {
                $lastTimestamp = [datetime]::ParseExact($timestampString, 'yyyy-MM-dd HH:mm:ss', $null)
            } catch {
                $lastTimestamp = $null
            }
        }

        # Check if line contains any keyword (case-insensitive)
        $containsKeyword = $false
        foreach ($keyword in $keywords) {
            if ($line.IndexOf($keyword, [System.StringComparison]::InvariantCultureIgnoreCase) -ge 0) {
                $containsKeyword = $true
                break
            }
        }

        if ($containsKeyword -and $lastTimestamp -and $lastTimestamp.Date -eq $startOfToday) {
            $filteredLines += $line
        }
    }

    if ($filteredLines.Count -eq 0) {
        Write-Output "No matching entries found in CBS.log for today."
    } else {
        $filteredLines
    }
}



 
function Extract-KBFailures {
    param($logPath)
    Write-Output "`n=== Suspected Failed KB Updates ==="
    if (Test-Path $logPath) {
        Select-String -Path $logPath -Pattern 'KB\d{7}' | ForEach-Object {
            $_.Matches.Value
        } | Sort-Object | Get-Unique
    }
}
 
