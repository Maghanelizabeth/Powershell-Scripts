function Get-EventViewerLogs {
    Write-Output "`n=== Event Viewer Logs for Windows Update ==="
    $events = Get-WinEvent -LogName "System" | Where-Object {
        $_.ProviderName -eq "Microsoft-Windows-WindowsUpdateClient" -and $_.Id -eq 20
    }
 
    $events | ForEach-Object {
        "Event ID: $($_.Id) - Time: $($_.TimeCreated) - Message: $($_.Message)"
    }
}
 
# === MAIN EXECUTION ===
 
$windowsUpdateLog = "$env:TEMP\WindowsUpdate.log"
Write-Output "`nGenerating latest WindowsUpdate.log..."
Get-WindowsUpdateLog -LogPath $windowsUpdateLog | Out-Null
 
$cbsLog = "C:\Windows\Logs\CBS\CBS.log"
 
$systemSummary = Get-SystemSummary
$systemSummary | Format-List
 
$wuErrors = Parse-WindowsUpdateLog -logPath $windowsUpdateLog
$cbsErrors = Parse-CBSLog -logPath $cbsLog
 
$failedKBs = Extract-KBFailures -logPath $cbsLog
 
$allLogs = $wuErrors + $cbsErrors
$suggestions = Suggest-Remediation -logLines $allLogs
 
$eventLogs = Get-EventViewerLogs
 
$reportPath = "C:\WindowsUpdateDiagnostics_$(Get-Date -Format 'yyyyMMdd_HHmmss').txt"
$reportContent = @()
 
$reportContent += $systemSummary | Format-List | Out-String
$reportContent += $wuErrors
$reportContent += $cbsErrors
$reportContent += $eventLogs
$reportContent += $failedKBs
$reportContent += $suggestions
 
$reportContent | Out-File -FilePath $reportPath
 
Write-Output "`nDiagnostic report saved to $reportPath"



